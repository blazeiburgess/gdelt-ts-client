{
  "name": "gdelt-ts-client",
  "version": "1.4.0",
  "description": "TypeScript client for the GDELT API with full type support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blazeiburgess/gdelt-ts-client.git"
  },
  "homepage": "https://github.com/blazeiburgess/gdelt-ts-client#readme",
  "bugs": {
    "url": "https://github.com/blazeiburgess/gdelt-ts-client/issues"
  },
  "scripts": {
    "build": "tsc",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "prebuild": "npm run clean",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "npm run build"
  },
  "dependencies": {
    "undici": "^7.8.0"
  },
  "peerDependencies": {
    "@mozilla/readability": "^0.6.0",
    "jsdom": "^26.1.0"
  },
  "peerDependenciesMeta": {
    "@mozilla/readability": {
      "optional": true
    },
    "jsdom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mozilla/readability": "^0.6.0",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.1",
    "globals": "^13.24.0",
    "jest": "^30.0.4",
    "jsdom": "^26.1.0",
    "ts-jest": "^29.4.0",
    "typescript": "^5.5.3"
  },
  "keywords": [
    "gdelt",
    "api",
    "client",
    "typescript",
    "news",
    "data",
    "analytics"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "private": false,
  "license": "MIT"
}
